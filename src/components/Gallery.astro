---
import { getCollection } from 'astro:content';

const galeriaEntries = await getCollection('galeria');
const galeria = galeriaEntries[0];

const imagens = [
  { file: 'images/galeria-clovis-guitar.png', alt: 'Clóvis Ribeiro tocando guitarra elétrica no estúdio de gravação' },
  { file: 'images/galeria-clovis-violao2.png', alt: 'Clóvis Ribeiro dedilhando violão durante ensaio no estúdio' },
  { file: 'images/galeria-clovis-voz2.png', alt: 'Clóvis Ribeiro cantando próximo ao microfone de estúdio' },
  { file: 'images/galeria-geral-clovis-baixo.png', alt: 'Clóvis Ribeiro tocando contrabaixo elétrico no estúdio' },
  { file: 'images/galeria-geral-clovis-voz.png', alt: 'Plano médio de Clóvis Ribeiro cantando no estúdio de gravação' },
  { file: 'images/galeria-geral-mesa-equipamentos.jpeg', alt: 'Mesa de som e equipamentos periféricos no estúdio da Rede Daora' },
];
---

<section class="gallery">
  <div class="container">
    <span class="eyebrow">{galeria?.data.eyebrow}</span>
    <h2 class="section-title">{galeria?.data.heading}</h2>
    <p class="section-desc">{galeria?.data.description}</p>
    <div class="gallery-grid" id="gallery-grid">
      {imagens.map((img, i) => (
        <div class="gallery-item" data-index={i}>
          <img src={`/${img.file}`} alt={img.alt} loading="lazy">
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    padding: 2rem 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 720px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.2rem;
    }
  }

  .gallery-item {
    position: relative;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 4/3;
    transition: all 0.25s;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(15%) contrast(1.05);
    transition: all 0.25s;
  }

  .gallery-item:hover {
    transform: scale(1.04);
    box-shadow: 0 0 0 3px var(--complement);
  }

  .gallery-item:hover img {
    filter: grayscale(0%) contrast(1.05);
  }
</style>
