---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Clóvis Ribeiro — Ouça o novo single Todos os Meses, produzido pela turma de Sonoplastia da Rede Daora' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="noindex, nofollow">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>

  <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>

  <slot />

</body>
</html>

<style>
  :global(.container) {
    width: min(calc(100% - 2rem), var(--max));
    margin-inline: auto;
  }
</style>
