---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const [pagina] = await getCollection('paginas', ({ data }) => data.pageSlug === 'termos');
const { Content } = pagina ? await pagina.render() : { Content: null };
---

<BaseLayout title="Termos de Uso — Sonoplastia 2026">
  <Header />
  <main id="conteudo">
    <section class="legal-page">
      <div class="container">
        <article class="legal-card">
          <h1>{pagina?.data.title}</h1>
          <p class="legal-updated">Atualizado em: {pagina?.data.updated}</p>
          {Content && <Content />}
        </article>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal-page {
    padding: 3rem 0;
    min-height: 70vh;
  }

  .legal-card {
    max-width: 800px;
    margin: 0 auto;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.03));
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 2.5rem;
  }

  .legal-card :global(h1) {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .legal-updated {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .legal-card :global(h2) {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--accent);
    margin: 1.5rem 0 0.75rem;
  }

  .legal-card :global(p) {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .legal-card :global(ul) {
    color: var(--text-secondary);
    margin: 0.5rem 0 1rem 1.5rem;
    line-height: 1.7;
  }

  .legal-card :global(li) {
    margin-bottom: 0.4rem;
  }

  .legal-card :global(strong) {
    color: var(--text-primary);
  }
</style>
